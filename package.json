{
  "name": "omnia-foodcourt-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/src/main.js",
    "build": "prisma generate && nest build",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "seed:demo": "tsx prisma/seed-demo.ts",
    "migration:preflight:core": "tsx scripts/vertical-migration/preflight.ts --vertical=core",
    "migration:preflight:hris": "tsx scripts/vertical-migration/preflight.ts --vertical=hris",
    "migration:preflight:cafe": "tsx scripts/vertical-migration/preflight.ts --vertical=cafe",
    "migration:reconcile:core": "tsx scripts/vertical-migration/preflight.ts --vertical=core --reconcile",
    "migration:reconcile:hris": "tsx scripts/vertical-migration/preflight.ts --vertical=hris --reconcile",
    "migration:reconcile:cafe": "tsx scripts/vertical-migration/preflight.ts --vertical=cafe --reconcile",
    "migration:copy:core": "tsx scripts/vertical-migration/copy.ts --vertical=core",
    "migration:copy:hris": "tsx scripts/vertical-migration/copy.ts --vertical=hris",
    "migration:copy:cafe": "tsx scripts/vertical-migration/copy.ts --vertical=cafe",
    "smoke:hris": "node scripts/hris-smoke-test.js",
    "smoke:fnb": "node scripts/fnb-smoke-test.js",
    "smoke:social-commerce": "node scripts/social-commerce-smoke-test.js",
    "test:hris:full": "node scripts/hris-full-e2e-test.js",
    "clear:fnb": "tsx scripts/clear-fnb-operational-data.ts",
    "clear:testing-data": "tsx scripts/clear-omnia-testing-data.ts",
    "encrypt-sensitive-fields": "tsx scripts/encrypt-sensitive-fields.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.11",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^10.4.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.17.0",
    "globals": "^15.15.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.1"
  }
}
