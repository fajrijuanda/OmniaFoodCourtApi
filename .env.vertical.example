# Source database remains DATABASE_URL in .env. Never commit real connection strings.
CORE_DATABASE_URL="postgresql://..."
HRIS_DATABASE_URL="postgresql://..."
CAFE_DATABASE_URL="postgresql://..."

# All three services must validate the same signed access token during cutover.
JWT_SECRET="replace-with-the-current-production-secret-in-Vercel-only"
OMNIA_SERVICE_SCOPE="core"
