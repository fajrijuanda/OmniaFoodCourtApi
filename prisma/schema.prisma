  classId   String   @map("class_id")
  class     CampusClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId String   @map("student_id")
  student   CampusStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  midterm   Decimal?
  finalExam Decimal? @map("final_exam")
  assignment Decimal?
  total     Decimal?
  letter    String?  // A, AB, B, BC, C, D, E
  status    String   @default("draft") // draft, published, approved
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([classId, studentId])
  @@index([tenantId, classId])
  @@map("campus_grades")
}

model CampusKknPeriod {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?  @map("branch_id")
  branch      TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name        String   // "KKN Tematik 2026"
  academicYear String? @map("academic_year")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  status      String   @default("active") // planning, active, completed
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  groups    CampusKknGroup[]

  @@index([tenantId, status])
  @@map("campus_kkn_periods")
}

model CampusKknGroup {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId   String?  @map("branch_id")
  branch     TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  periodId   String   @map("period_id")
  period     CampusKknPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  locationId String?  @map("location_id")
  location   CampusKknLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  code       String   // "KKN-CRB-04"
  supervisorName String? @map("supervisor_name")
  status     String   @default("active") // formed, active, completed
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  members   CampusKknGroupMember[]
  logbooks  CampusKknLogbook[]
  reports   CampusKknReport[]

  @@index([tenantId, periodId])
  @@map("campus_kkn_groups")
}

model CampusKknGroupMember {
  id        String   @id @default(cuid())
  groupId   String   @map("group_id")
  group     CampusKknGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId String   @map("student_id")
  student   CampusStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  role      String   @default("member") // leader, member
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([groupId, studentId])
  @@map("campus_kkn_group_members")
}

model CampusKknLocation {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?  @map("branch_id")
  branch      TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name        String   // "Desa Caman Raya Bekasi"
  address     String?  @db.Text
  coordinator String?  // nama koordinator
  capacity    Int      @default(20)
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  groups    CampusKknGroup[]

  @@index([tenantId, status])
  @@map("campus_kkn_locations")
}

model CampusKknLogbook {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId  String?  @map("branch_id")
  branch    TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  groupId   String   @map("group_id")
  group     CampusKknGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  date      DateTime
  activity  String   @db.Text
  evidence  String?  // file URL
  notes     String?  @db.Text
  status    String   @default("submitted") // submitted, reviewed, approved
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, groupId, date])
  @@map("campus_kkn_logbooks")
}

model CampusKknReport {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?  @map("branch_id")
  branch      TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  groupId     String   @map("group_id")
  group       CampusKknGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title       String
  fileUrl     String?  @map("file_url")
  score       Decimal?
  status      String   @default("draft") // draft, submitted, reviewed, approved
  reviewNotes String?  @map("review_notes") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId, groupId])
  @@map("campus_kkn_reports")
}

model CampusAcademicRequest {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?  @map("branch_id")
  branch      TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  studentId   String   @map("student_id")
  student     CampusStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type        String   // "Surat Aktif Kuliah", "Legalisir Transkrip", "Cuti Akademik"
  description String?  @db.Text
  owner       String?  // "BAAK", "Fakultas", "Kaprodi"
  sla         String?  // "1 hari", "3 hari"
  status      String   @default("submitted") // submitted, review, approved, rejected, ready
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  approvals CampusApproval[]
  documents CampusDocument[]

  @@index([tenantId, status])
  @@map("campus_academic_requests")
}

model CampusDocument {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?  @map("branch_id")
  branch      TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  requestId   String?  @map("request_id")
  request     CampusAcademicRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  name        String
  fileUrl     String?  @map("file_url")
  category    String?  // "Surat", "Transkrip", "Berkas"
  status      String   @default("uploaded") // uploaded, verified, rejected
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId, requestId])
  @@map("campus_documents")
}

model CampusApproval {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?  @map("branch_id")
  branch      TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  requestId   String?  @map("request_id")
  request     CampusAcademicRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  entityType  String   @map("entity_type") // "AcademicRequest", "Grade", "KknReport"
  entityId    String   @map("entity_id")
  approverRole String  @map("approver_role") // "BAAK", "Kaprodi", "Dosen", "LPPM"
  approverName String? @map("approver_name")
  status      String   @default("pending") // pending, approved, rejected
  notes       String?  @db.Text
  decidedAt   DateTime? @map("decided_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, entityType, entityId])
  @@map("campus_approvals")
}

model CampusInvoice {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId       String?  @map("branch_id")
  branch         TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  studentId      String   @map("student_id")
  student        CampusStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  invoiceNumber  String   @map("invoice_number")
  description    String?
  totalAmount    Decimal  @default(0) @map("total_amount")
  paidAmount     Decimal  @default(0) @map("paid_amount")
  status         String   @default("issued") // issued, paid, overdue, cancelled
  dueDate        DateTime? @map("due_date")
  paidAt         DateTime? @map("paid_at")
  issuedAt       DateTime @default(now()) @map("issued_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  payments CampusPayment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, studentId, status])
  @@map("campus_invoices")
}

model CampusPayment {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId   String?  @map("branch_id")
  branch     TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  invoiceId  String   @map("invoice_id")
  invoice    CampusInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount     Decimal
  method     String   @default("transfer")
  reference  String?
  status     String   @default("paid")
  paidAt     DateTime @default(now()) @map("paid_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, branchId, paidAt])
  @@map("campus_payments")
}

model CampusAnnouncement {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?  @map("branch_id")
  branch      TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  facultyId   String?  @map("faculty_id")
  faculty     CampusFaculty? @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  title       String
  body        String   @db.Text
  category    String?  // "Akademik", "KKN", "Umum", "LMS"
  priority    String   @default("normal") // high, normal, low
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId, category])
  @@map("campus_announcements")
}
