generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  user
  owner
  employee
}

enum TenantRole {
  owner
  admin
  employee
}

enum UserStatus {
  active
  inactive
}

enum SubscriptionStatus {
  trial
  subscribed
  unsubscribed
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  passwordHash    String       @map("password_hash")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  name            String
  phoneNumber     String?      @map("phone_number")
  phoneVerifiedAt DateTime?    @map("phone_verified_at")
  role            UserRole
  status          UserStatus   @default(active)
  oauthProvider   String?      @map("oauth_provider")
  oauthProviderId String?      @map("oauth_provider_id")
  tenantUsers     TenantUser[]
  notifications   Notification[]
  createdSubscriptions TenantSubscription[] @relation("TenantSubscriptionCreatedBy")
  createdCheckoutSessions BillingCheckoutSession[] @relation("CheckoutCreatedBy")
  purchasedAddOns TenantAddOn[] @relation("TenantAddOnPurchasedBy")
  employees       Employee[]
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  subIndustry     SubIndustry? @relation(fields: [subIndustryId], references: [id])
  subIndustryId   String?
  tier            Tier?        @relation(fields: [tierId], references: [id])
  tierId          String?
  tokenVersion    Int          @default(1) @map("token_version")

  @@index([oauthProvider, oauthProviderId])
  @@map("users")
}

model OtpChallenge {
  id          String    @id @default(cuid())
  phoneNumber String    @map("phone_number")
  codeHash    String    @map("code_hash")
  purpose     String    @default("register")
  attempts    Int       @default(0)
  expiresAt   DateTime  @map("expires_at")
  verifiedAt  DateTime? @map("verified_at")
  consumedAt  DateTime? @map("consumed_at")
  ip          String?
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([phoneNumber, purpose, createdAt])
  @@map("otp_challenges")
}

model Industry {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  iconKey       String        @map("icon_key")
  colorKey      String        @map("color_key")
  pain          String
  solution      String
  sortOrder     Int           @default(0) @map("sort_order")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  subIndustries SubIndustry[]

  @@map("industries")
}

model SubIndustry {
  id                  String               @id @default(cuid())
  industryId          String               @map("industry_id")
  industry            Industry             @relation(fields: [industryId], references: [id], onDelete: Cascade)
  name                String
  slug                String               @unique
  iconKey             String?              @map("icon_key")
  colorKey            String?              @map("color_key")
  need                String
  offer               String
  sortOrder           Int                  @default(0) @map("sort_order")
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  tiers               Tier[]
  features            Feature[]
  trialUsers          User[]
  tenantSubscriptions TenantSubscription[]
  billingCheckoutSessions BillingCheckoutSession[]

  @@map("sub_industries")
}

model Tier {
  id                  String               @id @default(cuid())
  subIndustryId       String               @map("sub_industry_id")
  subIndustry         SubIndustry          @relation(fields: [subIndustryId], references: [id], onDelete: Cascade)
  name                String
  slug                String               @unique
  price               String
  cadence             String
  description         String
  fit                 String
  limitsJson          Json                 @default("[]") @map("limits_json")
  sortOrder           Int                  @default(0) @map("sort_order")
  highlight           Boolean              @default(false)
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  tierFeatures        TierFeature[]
  trialUsers          User[]
  tenantSubscriptions TenantSubscription[]
  billingCheckoutSessions BillingCheckoutSession[]

  @@map("tiers")
}

model Feature {
  id            String        @id @default(cuid())
  subIndustryId String?       @map("sub_industry_id")
  subIndustry   SubIndustry?  @relation(fields: [subIndustryId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  sortOrder     Int           @default(0) @map("sort_order")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  tierFeatures  TierFeature[]

  @@map("features")
}

model TierFeature {
  id        String  @id @default(cuid())
  tierId    String  @map("tier_id")
  tier      Tier    @relation(fields: [tierId], references: [id], onDelete: Cascade)
  featureId String  @map("feature_id")
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  included  Boolean @default(false)

  @@unique([tierId, featureId])
  @@map("tier_features")
}

// --- HRIS SAAS MODELS ---

model Tenant {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("active")
  workLocationLat Decimal? @map("work_location_lat")
  workLocationLng Decimal? @map("work_location_lng")
  geofenceRadius  Int?     @default(100) @map("geofence_radius") // meters
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantUsers      TenantUser[]
  branches         TenantBranch[]
  roleProfiles     TenantRoleProfile[]
  auditLogs        TenantAuditLog[]
  subscriptions    TenantSubscription[]
  billingCheckoutSessions BillingCheckoutSession[]
  addOns           TenantAddOn[]
  departments      Department[]
  employees        Employee[]
  attendanceLogs   AttendanceLog[]
  leaveRequests    LeaveRequest[]
  payrollRuns      PayrollRun[]
  salaryComponents      SalaryComponent[]
  notifications         Notification[]
  reimbursementRequests ReimbursementRequest[]
  fieldReports          FieldReport[]
  performanceKpis       PerformanceKpi[]
  jobPostings           JobPosting[]
  jobApplicants         JobApplicant[]
  employeeLoanRequests  EmployeeLoanRequest[]

  // F&B POS Relations
  posCategories       PosCategory[]
  posProducts         PosProduct[]
  posPromoBanners     PosPromoBanner[]
  posModifierGroups   PosModifierGroup[]
  posOrders           PosOrder[]
  posShifts           PosShift[]
  posIngredients      PosIngredient[]
  posStockLogs        PosStockLog[]
  posTables           PosTable[]
  fnbPromoRules       FnbPromoRule[]
  fnbBakeryPreOrders  FnbBakeryPreOrder[]
  fnbWholesaleCustomers FnbWholesaleCustomer[]
  fnbWholesaleOrders  FnbWholesaleOrder[]
  fnbDeliveryIntegrations FnbDeliveryIntegration[]
  fnbDeliveryStatuses FnbDeliveryStatus[]
  fnbFoodCourtTenants FnbFoodCourtTenant[]
  fnbTenantSettlements FnbTenantSettlement[]

  // Social Commerce Intelligence Relations
  socialCommerceSettings SocialCommerceWorkspaceSetting[]
  socialCommerceConnectors SocialCommerceConnector[]
  socialCommerceProductTrends SocialCommerceProductTrend[]
  socialCommerceCreators SocialCommerceCreatorSignal[]
  socialCommerceCompetitors SocialCommerceCompetitorWatch[]
  socialCommerceActionCards SocialCommerceActionCard[]
  socialCommerceAlerts SocialCommerceAlert[]
  socialCommerceExperiments SocialCommerceExperiment[]
  socialCommerceReports SocialCommerceReport[]

  
  // Church System Relations
  churchMembers       ChurchMember[]
  churchCellGroups    ChurchCellGroup[]
  churchEvents        ChurchEvent[]
  churchVolunteerSchedules ChurchVolunteerSchedule[]
  churchDonations     ChurchDonation[]
  churchAssets        ChurchAsset[]

  clinicPatients      ClinicPatient[]
  clinicServices      ClinicService[]
  clinicAppointments  ClinicAppointment[]
  clinicQueueTickets  ClinicQueueTicket[]
  clinicVisits        ClinicVisit[]
  clinicPrescriptions ClinicPrescription[]
  clinicDrugs         ClinicDrug[]
  clinicDrugStocks    ClinicDrugStock[]
  clinicDrugMovements ClinicDrugMovement[]
  clinicPurchaseOrders ClinicPurchaseOrder[]
  clinicStockOpnames  ClinicStockOpname[]
  clinicInvoices      ClinicInvoice[]
  clinicPayments      ClinicPayment[]
  clinicCashierClosings ClinicCashierClosing[]
  clinicPatientTransfers ClinicPatientTransfer[]
  clinicLabMailboxMessages ClinicLabMailboxMessage[]
  clinicSatuSehatSyncLogs ClinicSatuSehatSyncLog[]

  // Campus / Higher Education Relations
  campusFaculties       CampusFaculty[]
  campusStudyPrograms   CampusStudyProgram[]
  campusCourses         CampusCourse[]
  campusClasses         CampusClass[]
  campusStudents        CampusStudent[]
  campusEnrollments     CampusEnrollment[]
  campusAttendances     CampusAttendance[]
  campusAssignments     CampusAssignment[]
  campusSubmissions     CampusSubmission[]
  campusGrades          CampusGrade[]
  campusKknPeriods      CampusKknPeriod[]
  campusKknGroups       CampusKknGroup[]
  campusKknLocations    CampusKknLocation[]
  campusKknLogbooks     CampusKknLogbook[]
  campusKknReports      CampusKknReport[]
  campusAcademicRequests CampusAcademicRequest[]
  campusDocuments       CampusDocument[]
  campusApprovals       CampusApproval[]
  campusInvoices        CampusInvoice[]
  campusPayments        CampusPayment[]
  campusAnnouncements   CampusAnnouncement[]

  fnbSettings         Json? @map("fnb_settings")
  hrisSettings        Json? @map("hris_settings")
  churchSettings      Json? @map("church_settings")
  campusSettings      Json? @map("campus_settings")

  @@map("tenants")
}

model Notification {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  title      String
  body       String
  category   String   // Payroll, Leave, Attendance, Employee, Entitlement, System
  priority   String   @default("normal") // high, normal, low
  status     String   @default("unread") // unread, read
  actionUrl  String?  @map("action_url") // optional deep link to portal page
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@index([tenantId, userId])
  @@map("notifications")
}

model TenantUser {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String     @map("tenant_id")
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      TenantRole @default(employee)
  roleProfileId String? @map("role_profile_id")
  roleProfile   TenantRoleProfile? @relation(fields: [roleProfileId], references: [id], onDelete: SetNull)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  branchAccess TenantUserBranch[]

  @@unique([userId, tenantId])
  @@map("tenant_users")
}

model TenantBranch {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  code            String
  status          String   @default("active")
  address         String?  @db.Text
  phoneNumber     String?  @map("phone_number")
  email           String?
  workLocationLat Decimal? @map("work_location_lat")
  workLocationLng Decimal? @map("work_location_lng")
  geofenceRadius  Int?     @map("geofence_radius")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  userAccess       TenantUserBranch[]
  departments      Department[]
  employees        Employee[]
  attendanceLogs   AttendanceLog[]
  leaveRequests    LeaveRequest[]
  payrollRuns      PayrollRun[]
  salaryComponents SalaryComponent[]
  reimbursementRequests ReimbursementRequest[]
  fieldReports     FieldReport[]
  performanceKpis  PerformanceKpi[]
  jobPostings      JobPosting[]
  jobApplicants    JobApplicant[]
  employeeLoanRequests EmployeeLoanRequest[]
  posTables        PosTable[]
  posCategories    PosCategory[]
  posProducts      PosProduct[]
  posPromoBanners  PosPromoBanner[]
  posModifierGroups PosModifierGroup[]
  posOrders        PosOrder[]
  posShifts        PosShift[]
  posIngredients   PosIngredient[]
  posStockLogs     PosStockLog[]
  fnbPromoRules    FnbPromoRule[]
  fnbBakeryPreOrders FnbBakeryPreOrder[]
  fnbWholesaleCustomers FnbWholesaleCustomer[]
  fnbWholesaleOrders FnbWholesaleOrder[]
  fnbDeliveryIntegrations FnbDeliveryIntegration[]
  fnbDeliveryStatuses FnbDeliveryStatus[]
  fnbFoodCourtTenants FnbFoodCourtTenant[]
  fnbTenantSettlements FnbTenantSettlement[]
  socialCommerceSettings SocialCommerceWorkspaceSetting[]
  socialCommerceConnectors SocialCommerceConnector[]
  socialCommerceProductTrends SocialCommerceProductTrend[]
  socialCommerceCreators SocialCommerceCreatorSignal[]
  socialCommerceCompetitors SocialCommerceCompetitorWatch[]
  socialCommerceActionCards SocialCommerceActionCard[]
  socialCommerceAlerts SocialCommerceAlert[]
  socialCommerceExperiments SocialCommerceExperiment[]
  socialCommerceReports SocialCommerceReport[]
  churchMembers    ChurchMember[]
  churchCellGroups ChurchCellGroup[]
  churchEvents     ChurchEvent[]
  churchVolunteerSchedules ChurchVolunteerSchedule[]
  churchDonations  ChurchDonation[]
  churchAssets     ChurchAsset[]
  auditLogs        TenantAuditLog[]
  subscriptions    TenantSubscription[]
  billingCheckoutSessions BillingCheckoutSession[]
  addOns           TenantAddOn[]
  clinicPatients   ClinicPatient[]
  clinicServices   ClinicService[]
  clinicAppointments ClinicAppointment[]
  clinicQueueTickets ClinicQueueTicket[]
  clinicVisits     ClinicVisit[]
  clinicPrescriptions ClinicPrescription[]
  clinicDrugs      ClinicDrug[]
  clinicDrugStocks ClinicDrugStock[]
  clinicDrugMovements ClinicDrugMovement[]
  clinicPurchaseOrders ClinicPurchaseOrder[]
  clinicStockOpnames ClinicStockOpname[]
  clinicInvoices   ClinicInvoice[]
  clinicPayments   ClinicPayment[]
  clinicCashierClosings ClinicCashierClosing[]
  outgoingClinicTransfers ClinicPatientTransfer[] @relation("ClinicTransferFromBranch")
  incomingClinicTransfers ClinicPatientTransfer[] @relation("ClinicTransferToBranch")
  clinicLabMailboxMessages ClinicLabMailboxMessage[]
  clinicSatuSehatSyncLogs ClinicSatuSehatSyncLog[]
  campusFaculties       CampusFaculty[]
  campusStudyPrograms   CampusStudyProgram[]
  campusCourses         CampusCourse[]
  campusClasses         CampusClass[]
  campusStudents        CampusStudent[]
  campusEnrollments     CampusEnrollment[]
  campusAttendances     CampusAttendance[]
  campusAssignments     CampusAssignment[]
  campusSubmissions     CampusSubmission[]
  campusGrades          CampusGrade[]
  campusKknPeriods      CampusKknPeriod[]
  campusKknGroups       CampusKknGroup[]
  campusKknLocations    CampusKknLocation[]
  campusKknLogbooks     CampusKknLogbook[]
  campusKknReports      CampusKknReport[]
  campusAcademicRequests CampusAcademicRequest[]
  campusDocuments       CampusDocument[]
  campusApprovals       CampusApproval[]
  campusInvoices        CampusInvoice[]
  campusPayments        CampusPayment[]
  campusAnnouncements   CampusAnnouncement[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("tenant_branches")
}

model TenantUserBranch {
  id           String       @id @default(cuid())
  tenantUserId String       @map("tenant_user_id")
  tenantUser   TenantUser   @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)
  branchId     String       @map("branch_id")
  branch       TenantBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now()) @map("created_at")

  @@unique([tenantUserId, branchId])
  @@map("tenant_user_branches")
}

model TenantRoleProfile {
  id          String       @id @default(cuid())
  tenantId    String       @map("tenant_id")
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  permissions Json         @default("[]")
  isSystem    Boolean      @default(false) @map("is_system")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tenantUsers TenantUser[]

  @@unique([tenantId, slug])
  @@map("tenant_role_profiles")
}

model TenantAuditLog {
  id           String        @id @default(cuid())
  tenantId     String        @map("tenant_id")
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId     String?       @map("branch_id")
  branch       TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  actorUserId  String?       @map("actor_user_id")
  action       String
  module       String
  entityType   String?       @map("entity_type")
  entityId     String?       @map("entity_id")
  before       Json?
  after        Json?
  ip           String?
  userAgent    String?       @map("user_agent")
  createdAt    DateTime      @default(now()) @map("created_at")

  @@index([tenantId, branchId, createdAt])
  @@index([tenantId, action])
  @@map("tenant_audit_logs")
}

model TenantSubscription {
  id               String      @id @default(cuid())
  tenantId         String      @map("tenant_id")
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId         String?     @map("branch_id")
  branch           TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdByUserId  String?     @map("created_by_user_id")
  createdByUser    User?       @relation("TenantSubscriptionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  subIndustryId    String      @map("sub_industry_id")
  subIndustry      SubIndustry @relation(fields: [subIndustryId], references: [id])
  tierId           String      @map("tier_id")
  tier             Tier        @relation(fields: [tierId], references: [id])
  status           String // trial, active, past_due, canceled
  startedAt        DateTime    @map("started_at")
  currentPeriodEnd DateTime    @map("current_period_end")
  price            Decimal     @default(0)
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@index([tenantId, branchId, status])
  @@index([createdByUserId])
  @@map("tenant_subscriptions")
}

model BillingCheckoutSession {
  id                String   @id @default(cuid())
  tenantId          String?  @map("tenant_id")
  tenant            Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId          String?  @map("branch_id")
  branch            TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdByUserId   String?  @map("created_by_user_id")
  createdByUser     User?    @relation("CheckoutCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  subIndustryId     String?  @map("sub_industry_id")
  subIndustry       SubIndustry? @relation(fields: [subIndustryId], references: [id])
  tierId            String?  @map("tier_id")
  tier              Tier?    @relation(fields: [tierId], references: [id])
  externalId        String   @unique @map("external_id")
  provider          String   @default("xendit")
  providerInvoiceId String?  @map("provider_invoice_id")
  checkoutUrl       String?  @map("checkout_url")
  source            String   @default("portal")
  action            String
  paymentMethod     String   @map("payment_method")
  customerName      String?  @map("customer_name")
  customerEmail     String?  @map("customer_email")
  customerPhone     String?  @map("customer_phone")
  itemsJson         Json     @default("[]") @map("items_json")
  subtotal          Decimal  @default(0)
  tax               Decimal  @default(0)
  gatewayFee        Decimal  @default(0) @map("gateway_fee")
  total             Decimal  @default(0)
  status            String   @default("pending")
  followUpStatus    String   @default("new") @map("follow_up_status")
  followUpNotes     String?  @map("follow_up_notes")
  lastFollowedUpAt  DateTime? @map("last_followed_up_at")
  paidAt            DateTime? @map("paid_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  tenantAddOns      TenantAddOn[]

  @@index([tenantId, status])
  @@index([tenantId, branchId, status])
  @@index([createdByUserId])
  @@map("billing_checkout_sessions")
}

model AddOn {
  id             String        @id @default(cuid())
  slug           String        @unique
  name           String
  category       String
  complexity     String
  price          String
  amount         Decimal       @default(0)
  cadence        String        @default("/ bulan")
  description    String        @db.Text
  bestFor        String        @map("best_for") @db.Text
  recommendedFor Json          @default("[]") @map("recommended_for")
  sourceApp      String?       @map("source_app")
  sortOrder      Int           @default(0) @map("sort_order")
  isActive       Boolean       @default(true) @map("is_active")
  tenantAddOns   TenantAddOn[]
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([category, isActive])
  @@map("add_ons")
}

model TenantAddOn {
  id                String      @id @default(cuid())
  tenantId          String      @map("tenant_id")
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId          String?     @map("branch_id")
  branch            TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  addOnId           String      @map("add_on_id")
  addOn             AddOn       @relation(fields: [addOnId], references: [id], onDelete: Restrict)
  status            String      @default("active")
  startedAt         DateTime    @map("started_at")
  currentPeriodEnd  DateTime?   @map("current_period_end")
  price             Decimal     @default(0)
  purchasedByUserId String?     @map("purchased_by_user_id")
  purchasedByUser   User?       @relation("TenantAddOnPurchasedBy", fields: [purchasedByUserId], references: [id], onDelete: SetNull)
  checkoutSessionId String?     @map("checkout_session_id")
  checkoutSession   BillingCheckoutSession? @relation(fields: [checkoutSessionId], references: [id], onDelete: SetNull)
  metadata          Json        @default("{}")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@index([tenantId, branchId, status])
  @@index([tenantId, addOnId])
  @@index([purchasedByUserId])
  @@map("tenant_add_ons")
}

model Department {
  id        String     @id @default(cuid())
  tenantId  String     @map("tenant_id")
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId  String?    @map("branch_id")
  branch    TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name      String
  code      String?
  employees Employee[]

  @@map("departments")
}

model Employee {
  id               String      @id @default(cuid())
  tenantId         String      @map("tenant_id")
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId         String?     @map("branch_id")
  branch           TenantBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  userId           String?     @unique @map("user_id")
  user             User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  departmentId     String?     @map("department_id")
  department       Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employeeNumber   String      @map("employee_number")
  email            String?
  fullName         String      @map("full_name")
  employmentStatus String      @map("employment_status") // PKWTT, PKWT, Probation, dll
